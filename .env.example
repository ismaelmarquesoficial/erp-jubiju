# ===== Bling OAuth2 =====
BLING_CLIENT_ID=seu_client_id
BLING_CLIENT_SECRET=seu_client_secret
BLING_REDIRECT_URI=https://SEU-DOMINIO/auth/bling/callback

# ===== Google Apps Script Webhook (grava na planilha) =====
GOOGLE_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# (legado) pasta do Drive — nao e mais usada para imagens
GOOGLE_DRIVE_FOLDER_ID=

# ===== Imagens hospedadas no proprio servidor =====
# Base publica usada para montar a URL das imagens na planilha
PUBLIC_BASE_URL=https://SEU-DOMINIO
# Pasta onde as imagens sao salvas. EM PRODUCAO: aponte para um VOLUME PERSISTENTE
IMAGES_DIR=/data/imagens

# ===== Servidor =====
PORT=80
